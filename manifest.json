{
  "manifest_version": 3,
  "name": "Sovereign AI Panel",
  "version": "1.6.1",
  "description": "Summarize, extract key points, look up a term and translate any web page via Infomaniak's AI API — data stays in Europe. Not affiliated with Infomaniak.",
  "browser_specific_settings": {
    "gecko": {
      "id": "sovereign-ai-panel@jsiikme",
      "strict_min_version": "127.0",
      "data_collection_permissions": {
        "required": ["websiteContent"]
      }
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.infomaniak.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "background": {
    "scripts": ["defaults.js", "background.js"]
  },
  "action": {
    "default_title": "Sovereign AI Panel",
    "default_icon": "icons/icon.svg"
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Open/close the assistant panel"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
